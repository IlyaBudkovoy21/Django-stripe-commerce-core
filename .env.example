DJANGO_ENV=development
DEBUG=True
SECRET_KEY=replace-me
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=UTC

# Database
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
# For PostgreSQL-like engines:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=stripe_core
# DATABASE_USER=stripe_core
# DATABASE_PASSWORD=stripe_core
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Stripe global defaults
STRIPE_API_VERSION=2024-06-20
STRIPE_DEFAULT_CURRENCY=usd
APP_BASE_URL=http://localhost:8000

# Production security flags
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Admin bootstrap
CREATE_SUPERUSER=False
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Stripe fallback credentials
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace

# Stripe keypair for USD
STRIPE_SECRET_KEY_USD=sk_test_replace_usd
STRIPE_PUBLISHABLE_KEY_USD=pk_test_replace_usd

# Stripe keypair for EUR
STRIPE_SECRET_KEY_EUR=sk_test_replace_eur
STRIPE_PUBLISHABLE_KEY_EUR=pk_test_replace_eur
